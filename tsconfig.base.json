{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "@rbac/api-common": ["./packages/api-common/src/index.ts"],
      "@rbac/api-common/*": ["./packages/api-common/src/*"]
    }
  }
}
