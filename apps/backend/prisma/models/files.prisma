model MediaAsset {
  id              String                    @id
  createId        String?
  updateId        String?
  userId          String
  kind            String
  originalName    String
  mimeType        String
  size            BigInt
  tag1            String?
  tag2            String?
  storageProvider MediaAssetStorageProvider @default(LOCAL)
  storageBucket   String
  objectKey       String                    @unique
  uploadToken     String                    @unique
  uploadStatus    MediaAssetUploadStatus    @default(PENDING)
  uploadStrategy  MediaAssetUploadStrategy  @default(SINGLE)
  chunkSize       Int?
  chunkCount      Int?
  etag            String?
  url             String?
  completedAt     DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  deleteAt        DateTime?
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarUsers     User[]                    @relation("UserAvatar")

  @@index([userId, kind])
  @@index([tag1])
  @@index([tag2])
  @@index([uploadStatus])
  @@index([deleteAt])
}
