generator client {
  provider = "prisma-client"
  output = "./generated"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum AuthIdentifierType {
  USERNAME
  EMAIL
  PHONE
}

enum AuthCredentialType {
  PASSWORD
  VERIFICATION_CODE
}

enum AuthVerificationPurpose {
  LOGIN
  REGISTER
}

enum AuthClientType {
  WEB
  UNI_WECHAT_MINIAPP
  APP
}

enum OAuthProviderProtocol {
  OIDC
  OAUTH2
}

enum OAuthProviderClientAuthMethod {
  CLIENT_SECRET_BASIC
  CLIENT_SECRET_POST
}

enum OAuthApplicationClientType {
  PUBLIC
  CONFIDENTIAL
}

enum OAuthStateKind {
  EXTERNAL_LOGIN
  AUTHORIZE_SESSION
  LOGIN_TICKET
}

enum OAuthTokenKind {
  AUTHORIZATION_CODE
  ACCESS_TOKEN
  REFRESH_TOKEN
  EXTERNAL_ACCESS_TOKEN
  EXTERNAL_REFRESH_TOKEN
}

enum OAuthCodeChallengeMethod {
  S256
  PLAIN
}

enum MediaAssetStorageProvider {
  LOCAL
  S3
}

enum MediaAssetUploadStatus {
  PENDING
  COMPLETED
  FAILED
}

enum MediaAssetUploadStrategy {
  SINGLE
  CHUNKED
}

enum RequestAuthMode {
  LOCAL
  OAUTH
  ANONYMOUS
}

enum OperationAccessKind {
  MANAGED
  RAW
}

enum OperationEffectKind {
  READ
  WRITE
}

enum MenuNodeType {
  DIRECTORY
  PAGE
  ACTION
}

model User {
  id              String               @id
  createId        String?
  updateId        String?
  username        String               @unique
  email           String?              @unique
  nickname        String
  avatarFileId    String?
  preferences     Json?
  status          UserStatus           @default(ACTIVE)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deleteAt        DateTime?
  avatarFile      MediaAsset?          @relation("UserAvatar", fields: [avatarFileId], references: [id], onDelete: Restrict)
  roles           UserRole[]
  authentications UserAuthentication[]
  refreshTokens   RefreshToken[]
  uploads         MediaAsset[]
  messages        ChatMessage[]
  oauthStates     OAuthState[]
  oauthUsers      OAuthUser[]
  oauthTokens     OAuthToken[]

  @@index([deleteAt])
}

model AuthClient {
  id            String         @id
  createId      String?
  updateId      String?
  code          String         @unique
  name          String
  type          AuthClientType
  description   String?
  config        Json
  secretHash    String
  salt          String
  enabled       Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deleteAt      DateTime?
  refreshTokens RefreshToken[]
  oauthStates   OAuthState[]

  @@index([deleteAt])
}

model AuthStrategy {
  id                  String                 @id
  createId            String?
  updateId            String?
  code                String                 @unique
  name                String
  description         String?
  identifierType      AuthIdentifierType
  credentialType      AuthCredentialType
  enabled             Boolean                @default(true)
  loginEnabled        Boolean                @default(true)
  registerEnabled     Boolean                @default(true)
  verificationEnabled Boolean                @default(false)
  mockEnabled         Boolean                @default(false)
  mockValue           String?
  sortOrder           Int                    @default(0)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  deleteAt            DateTime?
  authentications     UserAuthentication[]
  verificationCodes   VerificationCode[]

  @@index([deleteAt])
}

model UserAuthentication {
  id             String       @id
  createId       String?
  updateId       String?
  userId         String
  strategyId     String
  identifier     String
  credentialHash String?
  salt           String?
  verifiedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deleteAt       DateTime?
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategy       AuthStrategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@unique([strategyId, identifier])
  @@unique([userId, strategyId])
  @@index([userId])
  @@index([deleteAt])
}

model VerificationCode {
  id         String                  @id
  createId   String?
  updateId   String?
  strategyId String
  identifier String
  purpose    AuthVerificationPurpose
  codeHash   String
  salt       String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  deleteAt   DateTime?
  strategy   AuthStrategy            @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@index([strategyId, identifier, purpose])
  @@index([expiresAt])
  @@index([deleteAt])
}

model Role {
  id          String           @id
  createId    String?
  updateId    String?
  code        String           @unique
  name        String
  description String
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deleteAt    DateTime?
  users       UserRole[]
  permissions RolePermission[]

  @@index([deleteAt])
}

model Permission {
  id          String           @id
  createId    String?
  updateId    String?
  code        String           @unique
  name        String
  module      String
  action      String
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deleteAt    DateTime?
  roles       RolePermission[]
  menuNode    MenuNode?
  oauthApps   OAuthApplicationPermission[]
  realtimeTopics RealtimeTopic[]

  @@index([deleteAt])
}

model MenuNode {
  id           String       @id
  createId     String?
  updateId     String?
  code         String       @unique
  type         MenuNodeType
  title        String
  caption      String?
  description  String?
  icon         String?
  path         String?      @unique
  viewKey      String?      @unique
  sortOrder    Int          @default(0)
  parentId     String?
  permissionId String?      @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deleteAt     DateTime?
  parent       MenuNode?    @relation("MenuTree", fields: [parentId], references: [id])
  children     MenuNode[]   @relation("MenuTree")
  permission   Permission?  @relation(fields: [permissionId], references: [id], onDelete: SetNull)

  @@index([parentId, sortOrder])
  @@index([type])
  @@index([deleteAt])
}

model RealtimeTopic {
  id           String     @id
  createId     String?
  updateId     String?
  code         String     @unique
  name         String
  description  String?
  topicPattern String
  isSystem     Boolean    @default(false)
  permissionId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deleteAt     DateTime?
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@index([topicPattern])
  @@index([permissionId, deleteAt])
  @@index([deleteAt])
}

model UserRole {
  id        String   @id
  createId  String?
  updateId  String?
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deleteAt   DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId, deleteAt])
  @@index([roleId, deleteAt])
  @@index([deleteAt])
}

model RolePermission {
  id           String     @id
  createId     String?
  updateId     String?
  roleId       String
  permissionId String
  assignedAt   DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deleteAt     DateTime?
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId, deleteAt])
  @@index([permissionId, deleteAt])
  @@index([deleteAt])
}

model RefreshToken {
  id        String     @id
  createId  String?
  updateId  String?
  token     String     @unique
  userId    String
  clientId  String
  expiresAt DateTime
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deleteAt  DateTime?
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    AuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId, clientId])
  @@index([deleteAt])
}

model RequestRecord {
  id        String   @id
  createId  String?
  updateId  String?
  actorId   String?
  actorName String
  authMode  RequestAuthMode @default(ANONYMOUS)
  authClientId String?
  authClientCode String?
  authClientType AuthClientType?
  oauthApplicationId String?
  oauthApplicationCode String?
  method    String
  path      String
  ipAddress String?
  userAgent String?
  requestQuery Json?
  requestParams Json?
  requestBody Json?
  statusCode Int
  success   Boolean
  errorCode String?
  errorMessage String?
  errorDetail Json?
  operationCount Int @default(0)
  readCount Int @default(0)
  writeCount Int @default(0)
  startedAt DateTime
  finishedAt DateTime
  durationMs Int @default(0)
  operations Operation[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startedAt])
  @@index([actorId, startedAt])
  @@index([method, startedAt])
  @@index([statusCode, startedAt])
  @@index([success, startedAt])
}

model Operation {
  id        String              @id
  createId  String?
  updateId  String?
  requestRecordId String
  sequence  Int
  model     String
  operation String
  effectiveOperation String?
  accessKind OperationAccessKind
  effectKind OperationEffectKind
  committed Boolean          @default(true)
  softDelete Boolean            @default(false)
  succeeded Boolean             @default(true)
  primaryEntityId String?
  affectedCount Int             @default(0)
  affectedIds String[]
  query     Json?
  mutation  Json?
  result    Json?
  effect    Json?
  errorCode String?
  errorMessage String?
  startedAt DateTime
  finishedAt DateTime
  durationMs Int                @default(0)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  requestRecord RequestRecord   @relation(fields: [requestRecordId], references: [id], onDelete: Cascade)

  @@unique([requestRecordId, sequence])
  @@index([requestRecordId, startedAt])
  @@index([model, operation, startedAt])
  @@index([primaryEntityId])
  @@index([effectKind, startedAt])
}

model MediaAsset {
  id              String                    @id
  createId        String?
  updateId        String?
  userId          String
  kind            String
  originalName    String
  mimeType        String
  size            BigInt
  tag1            String?
  tag2            String?
  storageProvider MediaAssetStorageProvider @default(LOCAL)
  storageBucket   String
  objectKey       String                    @unique
  uploadToken     String                    @unique
  uploadStatus    MediaAssetUploadStatus    @default(PENDING)
  uploadStrategy  MediaAssetUploadStrategy  @default(SINGLE)
  chunkSize       Int?
  chunkCount      Int?
  etag            String?
  url             String?
  completedAt     DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  deleteAt        DateTime?
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarUsers     User[]                    @relation("UserAvatar")

  @@index([userId, kind])
  @@index([tag1])
  @@index([tag2])
  @@index([uploadStatus])
  @@index([deleteAt])
}

model ChatMessage {
  id        String   @id
  createId  String?
  updateId  String?
  senderId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deleteAt  DateTime?
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([deleteAt])
}

model OAuthProvider {
  id                 String                        @id
  createId           String?
  updateId           String?
  code               String                        @unique
  name               String
  description        String?
  logoUrl            String?
  protocol           OAuthProviderProtocol         @default(OIDC)
  issuer             String?
  discoveryUrl       String?
  authorizationEndpoint String
  tokenEndpoint      String
  userinfoEndpoint   String?
  jwksUri            String?
  clientId           String
  clientSecretEncrypted String?
  defaultScopes      String[]
  enabled            Boolean                       @default(true)
  allowLogin         Boolean                       @default(true)
  autoRegister       Boolean                       @default(true)
  autoLinkByEmail    Boolean                       @default(true)
  usePkce            Boolean                       @default(true)
  clientAuthMethod   OAuthProviderClientAuthMethod @default(CLIENT_SECRET_BASIC)
  claimMapping       Json
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt
  deleteAt           DateTime?
  users              OAuthUser[]
  states             OAuthState[]
  tokens             OAuthToken[]

  @@index([enabled, allowLogin])
  @@index([deleteAt])
}

model OAuthApplication {
  id                     String                     @id
  createId               String?
  updateId               String?
  code                   String                     @unique
  name                   String
  description            String?
  logoUrl                String?
  homepageUrl            String?
  clientId               String                     @unique
  clientType             OAuthApplicationClientType
  clientSecretHash       String?
  salt                   String?
  redirectUris           String[]
  postLogoutRedirectUris String[]
  defaultScopes          String[]
  enabled                Boolean                    @default(true)
  skipConsent            Boolean                    @default(false)
  requirePkce            Boolean                    @default(true)
  allowAuthorizationCode Boolean                    @default(true)
  allowRefreshToken      Boolean                    @default(true)
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  deleteAt               DateTime?
  permissions            OAuthApplicationPermission[]
  states                 OAuthState[]
  tokens                 OAuthToken[]

  @@index([enabled])
  @@index([deleteAt])
}

model OAuthApplicationPermission {
  id            String           @id
  createId      String?
  updateId      String?
  applicationId String
  permissionId  String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deleteAt      DateTime?
  application   OAuthApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  permission    Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([applicationId, permissionId])
  @@index([applicationId, deleteAt])
  @@index([permissionId, deleteAt])
  @@index([deleteAt])
}

model OAuthState {
  id          String         @id
  createId    String?
  updateId    String?
  kind        OAuthStateKind
  state       String         @unique
  providerId  String?
  applicationId String?
  userId      String?
  authClientId String?
  redirectUri String?
  nonce       String?
  codeVerifier String?
  payload     Json?
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deleteAt    DateTime?
  provider    OAuthProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  application OAuthApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  authClient  AuthClient?    @relation(fields: [authClientId], references: [id], onDelete: SetNull)

  @@index([kind, expiresAt])
  @@index([providerId])
  @@index([applicationId])
  @@index([userId])
  @@index([authClientId])
  @@index([deleteAt])
}

model OAuthUser {
  id             String        @id
  createId       String?
  updateId       String?
  userId         String
  providerId     String
  providerSubject String
  email          String?
  username       String?
  nickname       String?
  avatarUrl      String?
  rawProfile     Json?
  linkedAt       DateTime      @default(now())
  lastLoginAt    DateTime?
  lastSyncedAt   DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deleteAt       DateTime?
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       OAuthProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  tokens         OAuthToken[]

  @@unique([providerId, providerSubject])
  @@unique([userId, providerId])
  @@index([userId])
  @@index([providerId])
  @@index([deleteAt])
}

model OAuthToken {
  id                 String                   @id
  createId           String?
  updateId           String?
  kind               OAuthTokenKind
  tokenId            String                   @unique
  tokenHash          String?                  @unique
  encryptedValue     String?
  applicationId      String?
  providerId         String?
  oauthUserId        String?
  userId             String?
  sessionId          String?
  redirectUri        String?
  scope              String[]
  audience           String[]
  codeChallenge      String?
  codeChallengeMethod OAuthCodeChallengeMethod?
  nonce              String?
  expiresAt          DateTime
  refreshAt          DateTime?
  consumedAt         DateTime?
  revokedAt          DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  deleteAt           DateTime?
  application        OAuthApplication?        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  provider           OAuthProvider?           @relation(fields: [providerId], references: [id], onDelete: Cascade)
  oauthUser          OAuthUser?               @relation(fields: [oauthUserId], references: [id], onDelete: Cascade)
  user               User?                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([kind, expiresAt])
  @@index([applicationId, kind])
  @@index([providerId, kind])
  @@index([oauthUserId, kind])
  @@index([userId, kind])
  @@index([sessionId])
  @@index([refreshAt])
  @@index([deleteAt])
}
