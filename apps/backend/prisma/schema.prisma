generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum AuthIdentifierType {
  USERNAME
  EMAIL
  PHONE
}

enum AuthCredentialType {
  PASSWORD
  VERIFICATION_CODE
}

enum AuthVerificationPurpose {
  LOGIN
  REGISTER
}

enum MediaAssetStorageProvider {
  LOCAL
  S3
}

enum MediaAssetUploadStatus {
  PENDING
  COMPLETED
  FAILED
}

enum MediaAssetUploadStrategy {
  SINGLE
  CHUNKED
}

enum MenuNodeType {
  DIRECTORY
  PAGE
  ACTION
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  email         String?        @unique
  nickname      String
  avatar        String?
  status        UserStatus     @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  roles         UserRole[]
  authentications UserAuthentication[]
  refreshTokens RefreshToken[]
  activities    ActivityLog[]  @relation("ActivityActor")
  uploads       MediaAsset[]
  messages      ChatMessage[]
}

model AuthStrategy {
  id                 String                  @id @default(cuid())
  code               String                  @unique
  name               String
  description        String?
  identifierType     AuthIdentifierType
  credentialType     AuthCredentialType
  enabled            Boolean                 @default(true)
  loginEnabled       Boolean                 @default(true)
  registerEnabled    Boolean                 @default(true)
  verificationEnabled Boolean                @default(false)
  mockEnabled        Boolean                 @default(false)
  mockValue          String?
  sortOrder          Int                     @default(0)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  authentications    UserAuthentication[]
  verificationCodes  VerificationCode[]
}

model UserAuthentication {
  id             String       @id @default(cuid())
  userId         String
  strategyId     String
  identifier     String
  credentialHash String?
  salt           String?
  verifiedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategy       AuthStrategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@unique([strategyId, identifier])
  @@unique([userId, strategyId])
  @@index([userId])
}

model VerificationCode {
  id         String                  @id @default(cuid())
  strategyId String
  identifier String
  purpose    AuthVerificationPurpose
  codeHash   String
  salt       String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime                @default(now())
  strategy   AuthStrategy            @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@index([strategyId, identifier, purpose])
  @@index([expiresAt])
}

model Role {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  description String
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  module      String
  action      String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
  menuNode    MenuNode?
}

model MenuNode {
  id           String       @id @default(cuid())
  code         String       @unique
  type         MenuNodeType
  title        String
  caption      String?
  description  String?
  icon         String?
  path         String?      @unique
  viewKey      String?      @unique
  sortOrder    Int          @default(0)
  parentId     String?
  permissionId String?      @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  parent       MenuNode?    @relation("MenuTree", fields: [parentId], references: [id])
  children     MenuNode[]   @relation("MenuTree")
  permission   Permission?  @relation(fields: [permissionId], references: [id], onDelete: SetNull)

  @@index([parentId, sortOrder])
  @@index([type])
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  assignedAt   DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  actorId   String?
  actorName String
  action    String
  target    String
  detail    Json?
  createdAt DateTime @default(now())
  actor     User?    @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
}

model MediaAsset {
  id              String                    @id @default(cuid())
  userId          String
  kind            String
  originalName    String
  mimeType        String
  size            BigInt
  storageProvider MediaAssetStorageProvider @default(LOCAL)
  storageBucket   String
  objectKey       String                    @unique
  uploadToken     String                    @unique
  uploadStatus    MediaAssetUploadStatus    @default(PENDING)
  uploadStrategy  MediaAssetUploadStrategy  @default(SINGLE)
  chunkSize       Int?
  chunkCount      Int?
  etag            String?
  url             String?
  completedAt     DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
  @@index([uploadStatus])
}

model ChatMessage {
  id         String   @id @default(cuid())
  senderId   String
  content    String
  createdAt  DateTime @default(now())
  sender     User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}
