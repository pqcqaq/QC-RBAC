generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum AuthIdentifierType {
  USERNAME
  EMAIL
  PHONE
}

enum AuthCredentialType {
  PASSWORD
  VERIFICATION_CODE
}

enum AuthVerificationPurpose {
  LOGIN
  REGISTER
}

enum AuthClientType {
  WEB
  UNI_WECHAT_MINIAPP
  APP
}

enum MediaAssetStorageProvider {
  LOCAL
  S3
}

enum MediaAssetUploadStatus {
  PENDING
  COMPLETED
  FAILED
}

enum MediaAssetUploadStrategy {
  SINGLE
  CHUNKED
}

enum MenuNodeType {
  DIRECTORY
  PAGE
  ACTION
}

model User {
  id              String               @id
  createId        String?
  updateId        String?
  username        String               @unique
  email           String?              @unique
  nickname        String
  avatar          String?
  preferences     Json?
  status          UserStatus           @default(ACTIVE)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deleteAt        DateTime?
  roles           UserRole[]
  authentications UserAuthentication[]
  refreshTokens   RefreshToken[]
  activities      ActivityLog[]        @relation("ActivityActor")
  uploads         MediaAsset[]
  messages        ChatMessage[]

  @@index([deleteAt])
}

model AuthClient {
  id            String         @id
  createId      String?
  updateId      String?
  code          String         @unique
  name          String
  type          AuthClientType
  description   String?
  secretHash    String
  salt          String
  enabled       Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deleteAt      DateTime?
  refreshTokens RefreshToken[]

  @@index([deleteAt])
}

model AuthStrategy {
  id                  String                 @id
  createId            String?
  updateId            String?
  code                String                 @unique
  name                String
  description         String?
  identifierType      AuthIdentifierType
  credentialType      AuthCredentialType
  enabled             Boolean                @default(true)
  loginEnabled        Boolean                @default(true)
  registerEnabled     Boolean                @default(true)
  verificationEnabled Boolean                @default(false)
  mockEnabled         Boolean                @default(false)
  mockValue           String?
  sortOrder           Int                    @default(0)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  deleteAt            DateTime?
  authentications     UserAuthentication[]
  verificationCodes   VerificationCode[]

  @@index([deleteAt])
}

model UserAuthentication {
  id             String       @id
  createId       String?
  updateId       String?
  userId         String
  strategyId     String
  identifier     String
  credentialHash String?
  salt           String?
  verifiedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deleteAt       DateTime?
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategy       AuthStrategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@unique([strategyId, identifier])
  @@unique([userId, strategyId])
  @@index([userId])
  @@index([deleteAt])
}

model VerificationCode {
  id         String                  @id
  createId   String?
  updateId   String?
  strategyId String
  identifier String
  purpose    AuthVerificationPurpose
  codeHash   String
  salt       String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  deleteAt   DateTime?
  strategy   AuthStrategy            @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@index([strategyId, identifier, purpose])
  @@index([expiresAt])
  @@index([deleteAt])
}

model Role {
  id          String           @id
  createId    String?
  updateId    String?
  code        String           @unique
  name        String
  description String
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deleteAt    DateTime?
  users       UserRole[]
  permissions RolePermission[]

  @@index([deleteAt])
}

model Permission {
  id          String           @id
  createId    String?
  updateId    String?
  code        String           @unique
  name        String
  module      String
  action      String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deleteAt    DateTime?
  roles       RolePermission[]
  menuNode    MenuNode?

  @@index([deleteAt])
}

model MenuNode {
  id           String       @id
  createId     String?
  updateId     String?
  code         String       @unique
  type         MenuNodeType
  title        String
  caption      String?
  description  String?
  icon         String?
  path         String?      @unique
  viewKey      String?      @unique
  sortOrder    Int          @default(0)
  parentId     String?
  permissionId String?      @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deleteAt     DateTime?
  parent       MenuNode?    @relation("MenuTree", fields: [parentId], references: [id])
  children     MenuNode[]   @relation("MenuTree")
  permission   Permission?  @relation(fields: [permissionId], references: [id], onDelete: SetNull)

  @@index([parentId, sortOrder])
  @@index([type])
  @@index([deleteAt])
}

model UserRole {
  id        String   @id
  createId  String?
  updateId  String?
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deleteAt   DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId, deleteAt])
  @@index([roleId, deleteAt])
  @@index([deleteAt])
}

model RolePermission {
  id           String     @id
  createId     String?
  updateId     String?
  roleId       String
  permissionId String
  assignedAt   DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deleteAt     DateTime?
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId, deleteAt])
  @@index([permissionId, deleteAt])
  @@index([deleteAt])
}

model RefreshToken {
  id        String     @id
  createId  String?
  updateId  String?
  token     String     @unique
  userId    String
  clientId  String
  expiresAt DateTime
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deleteAt  DateTime?
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    AuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId, clientId])
  @@index([deleteAt])
}

model ActivityLog {
  id        String   @id
  createId  String?
  updateId  String?
  actorId   String?
  actorName String
  action    String
  target    String
  detail    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deleteAt  DateTime?
  actor     User?    @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([deleteAt])
}

model MediaAsset {
  id              String                    @id
  createId        String?
  updateId        String?
  userId          String
  kind            String
  originalName    String
  mimeType        String
  size            BigInt
  storageProvider MediaAssetStorageProvider @default(LOCAL)
  storageBucket   String
  objectKey       String                    @unique
  uploadToken     String                    @unique
  uploadStatus    MediaAssetUploadStatus    @default(PENDING)
  uploadStrategy  MediaAssetUploadStrategy  @default(SINGLE)
  chunkSize       Int?
  chunkCount      Int?
  etag            String?
  url             String?
  completedAt     DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  deleteAt        DateTime?
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
  @@index([uploadStatus])
  @@index([deleteAt])
}

model ChatMessage {
  id        String   @id
  createId  String?
  updateId  String?
  senderId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deleteAt  DateTime?
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([deleteAt])
}

